# OpenAI API Key (optional — mock LLM used when absent)
OPENAI_API_KEY=

# Server configuration
PORT=3001
WS_PORT=3002

# Database
SQLITE_DB_PATH=./data/audit.db

# LLM Configuration
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=4096
CONTEXT_TOKEN_THRESHOLD=2000

# Mock service mode (set to 'true' for in-process mocks)
USE_MOCK_SERVICES=true
